    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.3",
    "next": "16.2.9",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
